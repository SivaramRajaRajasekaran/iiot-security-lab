    {
        "id": "bc91313a5470efe3",
        "type": "function",
        "z": "b722b932422c7e6e",
        "name": "Parse & Validate",
        "func": "// Guard against malformed messages\nlet data;\ntry {\n    data = (typeof msg.payload === 'string') ? JSON.parse(msg.payload) : msg.payload;\n} catch(e) {\n    node.warn('Invalid JSON: ' + msg.payload);\n    return null;\n}\n\n// Validate required fields\nif (!data.machine_id || data.status === undefined || data.temperature === undefined) {\n    node.warn('Missing fields: ' + JSON.stringify(data));\n    return null;\n}\n\nmsg.payload = data;\nmsg.machine_id = data.machine_id;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
