    {
        "id": "5dccb91ec46aa73f",
        "type": "function",
        "z": "b722b932422c7e6e",
        "name": "IDS ENGINE",
        "func": "// ══════════════════════════════════════════════════════════\n// OT-IDS ENGINE — Intrusion Detection System\n// Checks every incoming MQTT message against security rules\n// Triggers alerts when attacks are detected\n// ══════════════════════════════════════════════════════════\n\nconst data = msg.payload;\nconst mid = data.machine_id;\nconst now = Date.now();\n\n// ── Configuration ─────────────────────────────────────────\n\n// Only these 4 machines are legitimate in our system\n// Any other machine_id is an intruder\nconst VALID_MACHINES = [\n    'machine1', 'machine2', 'machine3', 'machine4'\n];\n\n\n// From recon we saw normal range is 30-80°C\n// Below 28°C when ON = likely injection attack\n// Above 85°C = dangerous overheating OR spoofed high value\nconst TEMP_MIN_ON = 28;\nconst TEMP_MAX = 85;\n\n// Normal rate = 4 machines × 1 msg per 3s = ~1.3 msg/s\n// Flood threshold = if we see more than 10 msgs in 3s\n// that's 7x normal rate — definitely a flood\nconst FLOOD_THRESHOLD = 10;\nconst FLOOD_WINDOW_MS = 3000;\n\n// Real machines start from 0 and increment by 1-6 per cycle\n// Attack 1 sends random counts between 9000-9999\n// If production_count jumps to >8000 suddenly it's suspicious\nconst SUSPICIOUS_COUNT = 8000;\n\n// ── Rate tracking (stored in flow context) ────────────────\n\n// We need to track message timestamps across multiple messages\n// flow context persists between messages unlike local variables\nlet messageTimestamps = flow.get('ids_timestamps') || [];\n\n// Add current timestamp\nmessageTimestamps.push(now);\n\n// Keep only timestamps within the flood window\nmessageTimestamps = messageTimestamps.filter(\n    t => now - t < FLOOD_WINDOW_MS\n);\n\n// Save back to flow context\nflow.set('ids_timestamps', messageTimestamps);\n\nconst messagesInWindow = messageTimestamps.length;\n\n// ── Alert builder ─────────────────────────────────────────\nfunction buildAlert(type, severity, machine, detail) {\n    return {\n        type: type,\n        severity: severity,  // LOW, MEDIUM, HIGH, CRITICAL\n        machine_id: machine,\n        detail: detail,\n        timestamp: new Date().toISOString(),\n        raw_payload: data\n    };\n}\n\n// ── Rule 1: Unknown Machine ID ────────────────────────────\n// Catches Attack 3 spoofing and ghost machines\n// Any message from an unrecognised machine_id is suspicious\nif (!VALID_MACHINES.includes(mid)) {\n    const alert = buildAlert(\n        'UNKNOWN_MACHINE_ID',\n        'HIGH',\n        mid,\n        `Unknown machine_id detected: \"${mid}\". ` +\n        `Valid IDs are: ${VALID_MACHINES.join(', ')}`\n    );\n    node.warn(`[IDS] ALERT: ${alert.type} — ${alert.detail}`);\n    return { payload: alert, topic: 'ids/alert' };\n}\n\n// ── Rule 2: Temperature Out of Range ──────────────────────\n// Catches Attack 1 data injection\n// When machine is ON, temperature should be in normal range\n// Suspiciously low temp when ON = attacker hiding overheating\n// Suspiciously high temp = dangerous condition or spoofed value\nif (data.status === 'ON') {\n    if (data.temperature < TEMP_MIN_ON) {\n        const alert = buildAlert(\n            'TEMPERATURE_ANOMALY',\n            'HIGH',\n            mid,\n            `Temperature ${data.temperature}°C is suspiciously ` +\n            `LOW for an ON machine. ` +\n            `Minimum expected: ${TEMP_MIN_ON}°C. ` +\n            `Possible data injection attack.`\n        );\n        node.warn(`[IDS] ALERT: ${alert.type} — ${alert.detail}`);\n        return { payload: alert, topic: 'ids/alert' };\n    }\n}\n\nif (data.temperature > TEMP_MAX) {\n    const alert = buildAlert(\n        'TEMPERATURE_CRITICAL',\n        'CRITICAL',\n        mid,\n        `Temperature ${data.temperature}°C exceeds ` +\n        `maximum threshold of ${TEMP_MAX}°C. ` +\n        `Possible overheating or spoofed high value.`\n    );\n    node.warn(`[IDS] ALERT: ${alert.type} — ${alert.detail}`);\n    return { payload: alert, topic: 'ids/alert' };\n}\n\n// ── Rule 3: Message Flood Detection ───────────────────────\n// Catches Attack 2 flooding\n// We count how many messages arrived in the last 3 seconds\n// If it exceeds our threshold, it's a flood attack\nif (messagesInWindow > FLOOD_THRESHOLD) {\n    // WHY rate limiting alerts:\n    // During a flood we'd generate hundreds of alerts per second\n    // We only alert once per 5 seconds to avoid alert flooding\n    const lastFloodAlert = flow.get('last_flood_alert') || 0;\n    if (now - lastFloodAlert > 5000) {\n        flow.set('last_flood_alert', now);\n        const alert = buildAlert(\n            'MESSAGE_FLOOD',\n            'CRITICAL',\n            mid,\n            `${messagesInWindow} messages received in ` +\n            `${FLOOD_WINDOW_MS}ms window. ` +\n            `Normal rate is ~4 messages per 3 seconds. ` +\n            `Possible DoS flood attack.`\n        );\n        node.warn(`[IDS] ALERT: ${alert.type} — ${alert.detail}`);\n        return { payload: alert, topic: 'ids/alert' };\n    }\n    return null; // suppress duplicate flood alerts\n}\n\n// ── Rule 4: Suspicious Production Count ───────────────────\n// Catches the fake 9000+ counts from Attack 1\n// Real machines start from 0 and increment gradually\n// A sudden jump to thousands is a sign of injected data\nif (data.production_count > SUSPICIOUS_COUNT) {\n    const alert = buildAlert(\n        'SUSPICIOUS_PRODUCTION_COUNT',\n        'MEDIUM',\n        mid,\n        `Production count ${data.production_count} is ` +\n        `suspiciously high. ` +\n        `Expected gradual increment from 0. ` +\n        `Possible injected data.`\n    );\n    node.warn(`[IDS] ALERT: ${alert.type} — ${alert.detail}`);\n    return { payload: alert, topic: 'ids/alert' };\n}\n\n// ── No threats detected ───────────────────────────────────\n// Return null = message is clean, no alert needed\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
