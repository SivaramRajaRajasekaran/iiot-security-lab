    {
        "id": "9acfa897e1f73183",
        "type": "function",
        "z": "b722b932422c7e6e",
        "name": "Format Alert",
        "func": "const alert = msg.payload;\n\nconst icons = {\n  'CRITICAL': '🚨',\n  'HIGH': '⚠️',\n  'MEDIUM': '🔶',\n  'LOW': 'ℹ️'\n};\n\nconst icon = icons[alert.severity] || '⚠️';\nconst time = new Date(alert.timestamp).toLocaleTimeString();\n\n// Short concise messages that fit the popup naturally\nconst shortMessages = {\n  'TEMPERATURE_ANOMALY': `Temp too low on ${alert.machine_id} — possible injection`,\n  'TEMPERATURE_CRITICAL': `Critical temp on ${alert.machine_id} — check immediately`,\n  'MESSAGE_FLOOD': `Flood attack detected — ${alert.machine_id}`,\n  'SUSPICIOUS_PRODUCTION_COUNT': `Fake count detected on ${alert.machine_id}`,\n  'UNKNOWN_MACHINE_ID': `Unknown machine \"${alert.machine_id}\" detected`\n};\n\nconst shortMsg = shortMessages[alert.type] || alert.detail;\n\nmsg.payload = `${icon} [${alert.severity}] ${shortMsg} | ${time}`;\n\nmsg.ui_control = {\n  colour: alert.severity === 'CRITICAL' ? '#c0392b' :\n    alert.severity === 'HIGH' ? '#e67e22' :\n      alert.severity === 'MEDIUM' ? '#f39c12' : '#2980b9'\n};\n\nreturn msg;",
