    {
        "id": "5042d71fc4095e42",
        "type": "function",
        "z": "b722b932422c7e6e",
        "name": "Downtime & Availability",
        "func": "const INTERVAL = 3;\n\n// machine_id based keys:\n// Each machine needs its own separate downtime and totalTime counter\n// If we used flow.get('downtime') for all machines, they'd all\n// mix together and the calculation would be meaningless\n// By using 'downtime_machine1', 'downtime_machine2' etc,\n// each machine has its own independent memory slot\nconst mid = msg.payload.machine_id;\n\nlet downtime = flow.get('downtime_' + mid) || 0;\nlet totalTime = flow.get('totalTime_' + mid) || 0;\n\ntotalTime += INTERVAL;\n\nif (msg.payload.status === 'OFF') {\n    downtime += INTERVAL;\n}\n\nconst runtime = totalTime - downtime;\nconst availability = totalTime > 0 ? (runtime / totalTime) * 100 : 0;\n\n// Save back with machine_id in the key name\nflow.set('downtime_' + mid, downtime);\nflow.set('totalTime_' + mid, totalTime);\n\n// Add to payload so InfluxDB stores them\nmsg.payload.downtime = downtime;\nmsg.payload.availability = Number(availability.toFixed(2));\n\n// Output 1: downtime for display widget\nconst msg1 = { payload: downtime, machine_id: mid };\n\n// Output 2: availability for display widget  \nconst msg2 = { payload: Number(availability.toFixed(2)), machine_id: mid };\n\n// Output 3: full record for InfluxDB\nconst fullRecord = {\n    payload: {\n        machine_id: mid,\n        status: msg.payload.status,\n        temperature: msg.payload.temperature,\n        production_count: msg.payload.production_count,\n        downtime: downtime,\n        availability: Number(availability.toFixed(2)),\n        timestamp: msg.payload.timestamp\n    }\n};\n\nreturn [msg1, msg2, fullRecord];",
        "outputs": 3,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 850,
        "y": 2760,
        "wires": [
